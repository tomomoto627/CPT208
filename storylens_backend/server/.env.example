# ---------- 大模型（OpenAI 兼容 SDK，三选一配置）----------

# 通义千问（百炼）— 推荐：OPENAI_* 三行 + 勿再填 DEEPSEEK_API_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY= your_dashscope_api_key_here
OPENAI_MODEL=qwen-turbo

# 国际地域示例（以当前文档为准）：
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# DeepSeek（仅当仍用 DeepSeek 时填写；与 OPENAI_API_KEY 同时存在时优先 OPENAI_API_KEY）
# DEEPSEEK_API_KEY=your_deepseek_key_here
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# 本地开发端口
# PORT=8787

# 当前端和后端分域部署时，填写前端地址以放行跨域
# 例如：https://museum-frontend.vercel.app
# CORS_ORIGIN=
